            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Digits"
        },
        "value": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Value"
        },
        "units": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Units"
        }
      },
      "title": "ResolutionSpec",
      "type": "object"
    },
    "Signal": {
      "additionalProperties": false,
      "description": "A measurable/sourceable parameter \u2014 the primary signal dimension.\n\nUsed for what's being measured or sourced: range defines the operating\nenvelope, accuracy/resolution define the quality of measurement.\nTop-level accuracy/resolution are defaults; ``specs`` holds condition-dependent\noverrides (e.g., accuracy varies with frequency).\n\nExample YAML (instrument):\n    signals:\n      voltage:\n        range: {min: 0.1, max: 1000, units: V}\n        accuracy: {pct_reading: 0.0035, pct_range: 0.0006}\n        resolution: {digits: 6.5}\n        specs:\n          - when:\n              frequency: {min: 3, max: 5, units: Hz}\n            accuracy: {pct_reading: 0.35, pct_range: 0.03}\n\nExample YAML (product):\n    signals:\n      voltage:\n        value: 3.3\n        units: V",
      "properties": {
        "range": {
          "anyOf": [
            {
              "$ref": "#/$defs/RangeSpec"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "accuracy": {
          "anyOf": [
            {
              "$ref": "#/$defs/AccuracySpec"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "resolution": {
          "anyOf": [
            {
              "$ref": "#/$defs/ResolutionSpec"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "value": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Value"
        },
        "units": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Units"
        },
        "specs": {
          "anyOf": [
            {
              "items": {
                "$ref": "#/$defs/SpecBand"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Specs"
        },
        "qualifier": {
          "anyOf": [
            {
              "$ref": "#/$defs/SpecQualifier"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "note": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Note"
        }
      },
      "title": "Signal",
      "type": "object"
    },
    "SpecBand": {
      "additionalProperties": false,
      "description": "Condition-dependent specification override for a parameter.\n\nEach band says \"at this operating point, here are the specs.\"\nThe ``when`` keys reference sibling parameter names (signals,\nconditions, or controls); multiple keys are ANDed (all must match).\nEmpty dict means unconditional (always applies).\n\nAny field that is ``None`` means \"no override \u2014 use the top-level default.\"\n\nExample YAML (accuracy varies with frequency):\n    specs:\n      - when:\n          frequency: {min: 3, max: 5, units: Hz}\n        accuracy: {pct_reading: 0.35, pct_range: 0.03}\n\nExample YAML (range derated at high frequency):\n    specs:\n      - when:\n          frequency: {min: 3e9, max: 6e9, units: Hz}\n        range: {min: -130, max: 5, units: dBm}\n        accuracy: {absolute: 0.8}",
      "properties": {
        "when": {
          "additionalProperties": {
            "anyOf": [
              {
                "$ref": "#/$defs/RangeSpec"
              },
              {
                "$ref": "#/$defs/PointSpec"
              },
              {
                "$ref": "#/$defs/ListSpec"
              },
              {
                "type": "string"
              },
              {
                "type": "number"
              },
              {
                "type": "boolean"
              },
              {
                "items": {
                  "anyOf": [
                    {
                      "type": "string"
                    },
                    {
                      "type": "number"
                    },
                    {
                      "type": "boolean"
                    }
                  ]
                },
                "type": "array"
              }
            ]
          },
          "title": "When",
          "type": "object"
        },
        "range": {
          "anyOf": [
            {
              "$ref": "#/$defs/RangeSpec"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "value": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Value"
        },
        "units": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Units"
        },
        "accuracy": {
          "anyOf": [
            {
              "$ref": "#/$defs/AccuracySpec"
            },
            {
              "type": "null"
