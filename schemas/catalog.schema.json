      "description": "Specification for measurement resolution.",
      "properties": {
        "bits": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Bits"
        },
        "digits": {
