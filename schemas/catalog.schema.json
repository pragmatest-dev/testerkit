{
  "$defs": {
    "AccuracySpec": {
      "additionalProperties": false,
      "description": "Specification for measurement accuracy.",
      "properties": {
        "pct_reading": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Pct Reading"
        },
        "pct_range": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Pct Range"
        },
        "absolute": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Absolute"
        },
        "units": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Units"
        }
      },
      "title": "AccuracySpec",
      "type": "object"
    },
    "Attribute": {
      "additionalProperties": false,
      "description": "A fixed hardware fact or performance characteristic.\n\nAttributes are not adjustable \u2014 they describe inherent instrument\ncapabilities like bandwidth, sample rate, or input impedance.\n\nWhen an attribute varies by operating condition (e.g., test current\ndepends on resistance range), use ``specs`` for condition-dependent\noverrides \u2014 same pattern as Signal.specs.\n\nExample YAML:\n    attributes:\n      bandwidth:\n        value: 200000000\n        units: Hz\n      operating_temperature:\n        range: {min: 0, max: 55, units: degC}\n      test_current:\n        value: 0.001\n        units: A\n        specs:\n          - when: {range: 100}\n            value: 0.001\n          - when: {range: 10000}\n            value: 0.0001\n      scpi_version:\n        value: \"1997.0\"\n      supported_emulations:\n        options: [\"8340\", \"8360\", \"83700\"]",
      "properties": {
        "value": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "string"
            },
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Value"
        },
        "range": {
          "anyOf": [
            {
              "$ref": "#/$defs/RangeSpec"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "options": {
          "anyOf": [
            {
              "items": {
                "anyOf": [
                  {
                    "type": "number"
                  },
                  {
                    "type": "string"
                  },
                  {
                    "type": "boolean"
                  }
                ]
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Options"
        },
        "units": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Units"
        },
        "specs": {
          "anyOf": [
            {
              "items": {
                "$ref": "#/$defs/SpecBand"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Specs"
        },
        "qualifier": {
          "anyOf": [
            {
              "$ref": "#/$defs/SpecQualifier"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "note": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Note"
        }
      },
      "title": "Attribute",
      "type": "object"
    },
    "ChannelTopology": {
      "additionalProperties": false,
      "description": "Physical topology of a single instrument channel.\n\nDescribes the physical terminals, connector type, and ground topology\nfor a channel. Used in catalog and instrument library entries to model\nhow instruments physically connect to the DUT.\n\nExample YAML:\n    \"1\":\n      label: \"6V/5A Output\"\n      terminals: [hi, lo, sense_hi, sense_lo]\n      connector: binding_post\n      ground: floating",
      "properties": {
        "label": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Label"
        },
        "terminals": {
          "items": {
            "$ref": "#/$defs/TerminalRole"
          },
          "title": "Terminals",
          "type": "array"
        },
        "connector": {
          "anyOf": [
            {
              "$ref": "#/$defs/ConnectorType"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "connector_pin": {
          "anyOf": [
            {
              "additionalProperties": {
                "anyOf": [
                  {
                    "type": "integer"
                  },
                  {
                    "type": "string"
                  }
                ]
              },
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Connector Pin"
        },
        "ground": {
          "$ref": "#/$defs/GroundTopology",
          "default": "shared"
        },
        "optional": {
          "default": false,
          "title": "Optional",
          "type": "boolean"
        }
      },
      "title": "ChannelTopology",
      "type": "object"
    },
    "Condition": {
      "additionalProperties": false,
      "description": "An operating condition that affects accuracy of other parameters.\n\nConditions are NOT user-adjustable \u2014 they describe the operating\nenvironment or calibration state under which specs were characterized.\nUse controls for user-settable parameters.\n\nExample YAML (continuous):\n    conditions:\n      frequency:\n        range: {min: 3, max: 300000, units: Hz}\n\nExample YAML (discrete):\n    conditions:\n      calibration_interval:\n        options: [\"24_hour\", \"90_day\", \"1_year\", \"2_year\"]",
      "properties": {
        "range": {
          "anyOf": [
            {
              "$ref": "#/$defs/RangeSpec"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "options": {
          "anyOf": [
            {
              "items": {
                "anyOf": [
                  {
                    "type": "number"
                  },
                  {
                    "type": "string"
                  },
                  {
                    "type": "boolean"
                  }
                ]
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Options"
        },
        "units": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Units"
        },
        "default": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "string"
            },
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Default"
        },
        "specs": {
          "anyOf": [
            {
              "items": {
                "$ref": "#/$defs/SpecBand"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Specs"
        },
        "note": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Note"
        }
      },
      "title": "Condition",
      "type": "object"
    },
    "ConnectorType": {
      "description": "Physical connector type on instrument.",
      "enum": [
        "binding_post",
        "banana",
        "bnc",
        "terminal_block",
        "probe",
        "triax",
        "sma",
        "smb",
        "spring",
        "pxi",
        "screw_terminal",
        "dsub",
        "vhdci",
        "apc_3.5",
        "type_n",
        "k_2.4mm",
        "v_1.85mm",
        "phoenix",
        "tekvpi",
        "d_sub_9",
        "d_sub_15",
        "proprietary"
      ],
      "title": "ConnectorType",
      "type": "string"
    },
    "Control": {
      "additionalProperties": false,
      "description": "A user-configurable knob or setting.\n\nControls are instrument settings the user can adjust, like motor position,\ntemperature setpoint, or compliance limit. They have a range of valid\nvalues or a set of discrete options.\n\nExample YAML:\n    controls:\n      position:\n        range: {min: 0, max: 300, units: mm}\n      coupling:\n        options: [\"AC\", \"DC\"]\n        default: \"DC\"\n      autorange:\n        options: [true, false]\n        default: true",
      "properties": {
        "range": {
          "anyOf": [
            {
              "$ref": "#/$defs/RangeSpec"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "options": {
          "anyOf": [
            {
              "items": {
                "anyOf": [
                  {
                    "type": "number"
                  },
                  {
                    "type": "string"
                  },
                  {
                    "type": "boolean"
                  }
                ]
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Options"
        },
        "units": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Units"
        },
        "default": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "string"
            },
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Default"
        },
        "resolution": {
          "anyOf": [
            {
              "$ref": "#/$defs/ResolutionSpec"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "specs": {
          "anyOf": [
            {
              "items": {
                "$ref": "#/$defs/SpecBand"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Specs"
        },
        "note": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Note"
        }
      },
      "title": "Control",
      "type": "object"
    },
    "Direction": {
      "description": "Direction of signal flow for a capability.",
      "enum": [
        "input",
        "output",
        "bidir",
        "transform"
      ],
      "title": "Direction",
      "type": "string"
    },
    "GroundTopology": {
      "description": "How channel grounds relate to each other and earth.",
      "enum": [
        "floating",
        "shared",
        "earth"
      ],
      "title": "GroundTopology",
      "type": "string"
    },
    "InstrumentCapability": {
      "description": "Instrument capability + channels + operational metadata.\n\nExample YAML:\n    - function: dc_voltage\n      direction: input\n      signals:\n        voltage:\n          range: {min: 0.0001, max: 1000, units: V}\n          accuracy: {pct_reading: 0.0035, pct_range: 0.0006}\n          resolution: {digits: 6.5}\n      conditions:\n        frequency:\n          range: {min: 3, max: 300000, units: Hz}\n      channels: [\"1\"]\n      readback: false",
      "properties": {
        "function": {
          "$ref": "#/$defs/MeasurementFunction"
        },
        "direction": {
          "$ref": "#/$defs/Direction"
        },
        "signals": {
          "additionalProperties": {
            "$ref": "#/$defs/Signal"
          },
          "title": "Signals",
          "type": "object"
        },
        "conditions": {
          "additionalProperties": {
            "$ref": "#/$defs/Condition"
          },
          "title": "Conditions",
          "type": "object"
        },
        "controls": {
          "additionalProperties": {
            "$ref": "#/$defs/Control"
          },
          "title": "Controls",
          "type": "object"
        },
        "attributes": {
          "additionalProperties": {
            "$ref": "#/$defs/Attribute"
          },
          "title": "Attributes",
          "type": "object"
        },
        "units": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Units"
        },
        "specs": {
          "items": {
            "$ref": "#/$defs/SpecBand"
          },
          "title": "Specs",
          "type": "array"
        },
        "channels": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            }
          ],
          "title": "Channels"
        },
        "readback": {
          "default": false,
          "title": "Readback",
          "type": "boolean"
        }
      },
      "required": [
        "function",
        "direction"
      ],
      "title": "InstrumentCapability",
      "type": "object"
    },
    "ListSpec": {
      "additionalProperties": false,
      "description": "A discrete set of allowed values with optional units.\n\nUsed in SpecBand ``when`` clauses for membership matching\n(e.g., ``impedance: {values: [50, 600], units: ohm}``).",
      "properties": {
        "values": {
          "items": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "number"
              },
              {
                "type": "boolean"
              }
            ]
          },
          "title": "Values",
          "type": "array"
        },
        "units": {
          "default": "",
          "title": "Units",
          "type": "string"
        }
      },
      "required": [
        "values"
      ],
      "title": "ListSpec",
      "type": "object"
    },
    "MeasurementFunction": {
      "description": "Named signal measurement/stimulus functions.\n\nStandards-grounded taxonomy derived from IVI Foundation instrument classes,\nIEEE 1641 signal primitives, and SCPI naming conventions. Designed for ALL\nelectronics hardware test: DC, AC, RF, mixed-signal, digital, optical, thermal.\n\nDesign principles:\n- One enum for instruments AND products (direction distinguishes measure vs source)\n- Functions describe WHAT, not HOW (dc_voltage not dmm_dc_volts)\n- Flat enum (grouped by comment only, no hierarchy)\n- Waveform shapes are parameters, not functions (use WaveformShape enum)\n- Instrument-class-neutral (both DMM and scope can measure dc_voltage)",
      "enum": [
        "dc_voltage",
        "ac_voltage",
        "dc_current",
        "ac_current",
        "resistance",
        "resistance_4w",
        "capacitance",
        "inductance",
        "impedance",
        "frequency",
        "period",
        "temperature",
        "waveform",
        "dc_power",
        "ac_power",
        "rf_power",
        "rf_cw",
        "rf_am",
        "rf_fm",
        "rf_pm",
        "rf_sweep",
        "rf_iq",
        "rf_pulse",
        "s_parameters",
        "spectrum",
        "phase_noise",
        "noise_figure",
        "harmonics",
        "digital_pattern",
        "digital_io",
        "serial_data",
        "diode",
        "continuity",
        "dc_ratio",
        "quality_factor",
        "dissipation_factor",
        "time_interval",
        "pulse_width",
        "duty_cycle",
        "rise_time",
        "fall_time",
        "phase",
        "power_quality",
        "jitter",
        "eye_diagram",
        "thd",
        "snr",
        "gain",
        "return_loss",
        "insertion_loss",
        "vswr",
        "group_delay",
        "optical_power",
        "wavelength",
        "humidity",
        "charge",
        "magnetic_field",
        "position",
        "lock_in_detection",
        "heater_power",
        "excitation_current",
        "pulse_generation",
        "trigger",
        "reference_clock",
        "conductance",
        "reactance",
        "susceptance",
        "dynamic_load"
      ],
      "title": "MeasurementFunction",
      "type": "string"
    },
    "PointSpec": {
      "additionalProperties": false,
      "description": "A single numeric value with optional units.\n\nUsed in SpecBand ``when`` clauses when a point value needs explicit units\n(e.g., ``frequency: {value: 100000000, units: Hz}``).",
      "properties": {
        "value": {
          "title": "Value",
          "type": "number"
        },
        "units": {
          "default": "",
          "title": "Units",
          "type": "string"
        }
      },
      "required": [
        "value"
      ],
      "title": "PointSpec",
      "type": "object"
    },
    "RangeSpec": {
      "additionalProperties": false,
      "description": "Specification for measurement or output range.",
      "properties": {
        "min": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Min"
        },
        "max": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Max"
        },
        "units": {
          "default": "",
          "title": "Units",
          "type": "string"
        }
      },
      "title": "RangeSpec",
      "type": "object"
    },
    "ResolutionSpec": {
