{
  "$defs": {
    "FixtureConfig": {
      "description": "Test fixture definition (DUT interface).\n\nFixtures define how product pins connect to station instruments.\nThey can be scoped to:\n- A specific product (product_id)\n- A product family (product_family) - for shared fixtures\n- A specific revision (product_revision) - optional refinement\n\nFor simple setups without formal fixtures, tests can use:\n- Direct instrument access via fixtures (dmm, psu)\n- Ad-hoc pin mappings in test config",
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Name"
        },
        "product_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Product Id"
        },
        "product_family": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Product Family"
        },
        "product_revision": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Product Revision"
        },
        "points": {
          "additionalProperties": {
            "$ref": "#/$defs/FixturePoint"
          },
          "title": "Points",
          "type": "object"
        },
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Description"
        }
      },
      "required": [
        "id"
      ],
      "title": "FixtureConfig",
      "type": "object"
    },
    "FixturePoint": {
      "description": "A named routing junction on a test fixture.\n\nMaps a DUT connection point to an instrument channel and terminal,\nenabling complete signal routing traceability. Called \"Point\" rather\nthan \"Channel\" to avoid confusion with instrument channels.\n\nTerminology:\n- Pin: Physical DUT connection point (J1.1, TP5)\n- Net: Schematic signal name (VOUT_3V3)\n- FixturePoint: Named routing junction (vout_measure)\n- InstrumentChannel: Physical channel on instrument (CH1, ai0)\n- InstrumentTerminal: Physical terminal (hi, lo, signal)\n\nExample YAML:\n    vout_measure:\n      name: vout_measure\n      instrument: dmm\n      instrument_channel: \"1\"\n      instrument_terminal: hi\n      dut_pin: VOUT\n      net: \"VOUT_3V3\"",
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "instrument": {
          "title": "Instrument",
          "type": "string"
        },
        "instrument_channel": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Instrument Channel"
        },
        "instrument_terminal": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Instrument Terminal"
        },
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Description"
        },
        "dut_pin": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Dut Pin"
        },
        "net": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Net"
        }
      },
      "required": [
        "name",
        "instrument"
      ],
      "title": "FixturePoint",
      "type": "object"
    }
  },
  "description": "Schema for fixtures/*.yaml files.",
  "properties": {
    "fixture": {
      "$ref": "#/$defs/FixtureConfig"
    },
    "points": {
      "additionalProperties": {
        "$ref": "#/$defs/FixturePoint"
      },
      "title": "Points",
      "type": "object"
    }
  },
  "required": [
    "fixture"
  ],
  "title": "FixtureFile",
  "type": "object"
}
