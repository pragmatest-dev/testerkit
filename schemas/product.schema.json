    "Direction": {
      "description": "Direction of signal flow for a capability.",
      "enum": [
        "input",
        "output",
        "bidir",
        "transform"
      ],
      "title": "Direction",
      "type": "string"
    },
    "ListSpec": {
      "additionalProperties": false,
      "description": "A discrete set of allowed values with optional units.\n\nUsed in SpecBand ``when`` clauses for membership matching\n(e.g., ``impedance: {values: [50, 600], units: ohm}``).",
      "properties": {
        "values": {
          "items": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "number"
              },
              {
                "type": "boolean"
              }
            ]
          },
          "title": "Values",
          "type": "array"
        },
        "units": {
          "default": "",
          "title": "Units",
          "type": "string"
        }
      },
      "required": [
        "values"
      ],
      "title": "ListSpec",
      "type": "object"
    },
    "MeasurementFunction": {
      "description": "Named signal measurement/stimulus functions.\n\nStandards-grounded taxonomy derived from IVI Foundation instrument classes,\nIEEE 1641 signal primitives, and SCPI naming conventions. Designed for ALL\nelectronics hardware test: DC, AC, RF, mixed-signal, digital, optical, thermal.\n\nDesign principles:\n- One enum for instruments AND products (direction distinguishes measure vs source)\n- Functions describe WHAT, not HOW (dc_voltage not dmm_dc_volts)\n- Flat enum (grouped by comment only, no hierarchy)\n- Waveform shapes are parameters, not functions (use WaveformShape enum)\n- Instrument-class-neutral (both DMM and scope can measure dc_voltage)",
      "enum": [
        "dc_voltage",
        "ac_voltage",
        "dc_current",
        "ac_current",
        "resistance",
        "resistance_4w",
        "capacitance",
        "inductance",
        "impedance",
        "frequency",
        "period",
        "temperature",
        "waveform",
        "dc_power",
        "ac_power",
        "rf_power",
        "rf_cw",
        "rf_am",
        "rf_fm",
        "rf_pm",
        "rf_sweep",
        "rf_iq",
        "rf_pulse",
        "s_parameters",
        "spectrum",
        "phase_noise",
        "noise_figure",
        "harmonics",
        "digital_pattern",
        "digital_io",
        "serial_data",
        "diode",
        "continuity",
        "dc_ratio",
        "quality_factor",
        "dissipation_factor",
        "time_interval",
        "pulse_width",
        "duty_cycle",
        "rise_time",
        "fall_time",
        "phase",
        "power_quality",
        "jitter",
        "eye_diagram",
        "thd",
        "snr",
        "gain",
        "return_loss",
        "insertion_loss",
        "vswr",
        "group_delay",
        "optical_power",
        "wavelength",
        "humidity",
        "charge",
        "magnetic_field",
        "position",
        "lock_in_detection",
        "heater_power",
        "excitation_current",
        "pulse_generation",
        "trigger",
        "reference_clock",
        "conductance",
        "reactance",
        "susceptance",
        "dynamic_load"
      ],
      "title": "MeasurementFunction",
      "type": "string"
    },
    "Pin": {
      "additionalProperties": false,
      "description": "Physical pin/pad on the DUT (ATML: Port).\n\nRepresents a single connection point that can be routed through\na fixture to an instrument. The ``role`` field classifies the pin's\npurpose (signal, ground, power, reference) for fixture routing.\n\nExample YAML:\n    pins:\n      VIN:\n        name: \"J1.1\"\n        net: \"VIN_5V\"\n        role: power\n        description: \"5V power input from bench supply\"\n      VOUT:\n        name: \"J1.3\"\n        net: \"VOUT_3V3\"\n        description: \"3.3V regulated output\"\n      GND:\n        name: \"J1.2\"\n        net: \"GND\"\n        role: ground",
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "net": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Net"
        },
        "role": {
          "$ref": "#/$defs/PinRole",
          "default": "signal"
        },
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Description"
        }
      },
      "required": [
        "name"
      ],
      "title": "Pin",
      "type": "object"
    },
    "PinRole": {
      "description": "Role of a physical DUT pin in the test system.\n\nDistinguishes signal, ground, power, and reference pins so the\nauto-match algorithm can route them correctly (e.g., ground pins\nfan out to instrument LO terminals instead of competing for\nmeasurement channels).",
      "enum": [
        "signal",
        "ground",
        "power",
        "reference"
      ],
      "title": "PinRole",
      "type": "string"
    },
    "PointSpec": {
      "additionalProperties": false,
      "description": "A single numeric value with optional units.\n\nUsed in SpecBand ``when`` clauses when a point value needs explicit units\n(e.g., ``frequency: {value: 100000000, units: Hz}``).",
      "properties": {
        "value": {
          "title": "Value",
          "type": "number"
        },
        "units": {
          "default": "",
          "title": "Units",
          "type": "string"
        }
      },
      "required": [
        "value"
      ],
      "title": "PointSpec",
      "type": "object"
    },
    "ProductCharacteristic": {
      "description": "Product capability + physical interface + traceability (ATML: UUT Characteristic).\n\nExtends Capability with product-specific fields: physical pin mapping,\nnet names, signal groups, and datasheet references.\n\nThe direction indicates whether the DUT provides (OUTPUT) or consumes (INPUT)\nthis signal. Direction pairing for matching (DUT OUTPUT \u2192 instrument INPUT)\nlives in the matching service, not here.\n\nREQUIRES physical interface: Every characteristic must be tied to at least one\nphysical connection point (pin, net, or signal_group).\n\nExample YAML:\n    rail_3v3_output:\n      function: dc_voltage\n      direction: output\n      units: V\n      pin: VOUT\n      parameters:\n        voltage:\n          value: 3.3\n          units: V\n      specs:\n        - conditions:\n            temperature: {min: 25, max: 25, units: degC}\n            load: {min: 0.1, max: 0.1, units: A}\n          value: 3.3\n          accuracy: {pct_reading: 3.0}",
      "properties": {
        "function": {
          "$ref": "#/$defs/MeasurementFunction"
        },
        "direction": {
          "$ref": "#/$defs/Direction"
        },
        "signals": {
          "additionalProperties": {
            "$ref": "#/$defs/Signal"
          },
          "title": "Signals",
          "type": "object"
        },
        "conditions": {
          "additionalProperties": {
            "$ref": "#/$defs/Condition"
          },
          "title": "Conditions",
          "type": "object"
        },
        "controls": {
          "additionalProperties": {
            "$ref": "#/$defs/Control"
          },
          "title": "Controls",
          "type": "object"
        },
        "attributes": {
          "additionalProperties": {
            "$ref": "#/$defs/Attribute"
          },
          "title": "Attributes",
          "type": "object"
        },
        "units": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Units"
        },
        "specs": {
          "items": {
            "$ref": "#/$defs/SpecBand"
          },
          "title": "Specs",
          "type": "array"
        },
        "pin": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Pin"
        },
        "pins": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            }
          ],
          "title": "Pins"
        },
        "net": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Net"
        },
        "signal_group": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Signal Group"
        },
        "datasheet_ref": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Datasheet Ref"
        }
      },
      "required": [
        "function",
        "direction"
      ],
      "title": "ProductCharacteristic",
      "type": "object"
    },
    "RangeSpec": {
