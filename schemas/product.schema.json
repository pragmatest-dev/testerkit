  "$defs": {
    "AccuracySpec": {
      "additionalProperties": false,
      "description": "Specification for measurement accuracy.",
      "properties": {
        "pct_reading": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Pct Reading"
