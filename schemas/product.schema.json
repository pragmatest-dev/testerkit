{
  "$defs": {
    "AccuracySpec": {
      "description": "Specification for measurement accuracy.",
      "properties": {
        "pct_reading": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Pct Reading"
        },
        "pct_range": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Pct Range"
        },
        "absolute": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Absolute"
        }
      },
      "title": "AccuracySpec",
      "type": "object"
    },
    "BusSignal": {
      "description": "A signal within a bus group.\n\nExample YAML:\n    signals:\n      - pin: SDA\n        role: data\n      - pin: SCL\n        role: clock",
      "properties": {
        "pin": {
          "title": "Pin",
          "type": "string"
        },
        "role": {
          "title": "Role",
          "type": "string"
        },
        "index": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Index"
        }
      },
      "required": [
        "pin",
        "role"
      ],
      "title": "BusSignal",
      "type": "object"
    },
    "Characteristic": {
      "description": "A product characteristic tied to physical DUT interface (ATML: UUT Characteristic).\n\nUses MeasurementFunction + Direction + parameters to describe what the DUT does\nat a connection point. This is the product-side mirror of instrument FunctionCapability.\n\nThe direction indicates whether the DUT provides (OUTPUT) or consumes (INPUT)\nthis signal. Capability matching pairs OPPOSITE directions:\n- DUT OUTPUT -> Instrument INPUT (measure what DUT provides)\n- DUT INPUT -> Instrument OUTPUT (source what DUT needs)\n\nREQUIRES physical interface: Every characteristic must be tied to at least one\nphysical connection point (pin, net, or signal_group). This enables:\n- Fixture mapping (characteristic -> pin -> fixture point -> instrument channel)\n- Traceability from measurement back to schematic\n- Clear routing for test execution\n\nExample YAML:\n    rail_3v3_output:\n      function: dc_voltage\n      direction: output\n      units: V\n      pin: VOUT\n      parameters:\n        voltage:\n          value: 3.3\n          units: V\n      specs:\n        - conditions:\n            temperature: {min: 25, max: 25, units: degC}\n            load: {min: 0.1, max: 0.1, units: A}\n          value: 3.3\n          accuracy: {pct_reading: 3.0}",
      "properties": {
        "function": {
          "$ref": "#/$defs/MeasurementFunction",
          "default": "dc_voltage"
        },
        "direction": {
          "$ref": "#/$defs/Direction"
        },
        "parameters": {
          "additionalProperties": {
            "$ref": "#/$defs/SignalParameter"
          },
          "title": "Parameters",
          "type": "object"
        },
        "units": {
          "title": "Units",
          "type": "string"
        },
        "pin": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Pin"
        },
        "pins": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            }
          ],
          "title": "Pins"
        },
        "net": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Net"
        },
        "signal_group": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Signal Group"
        },
        "channel": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Channel"
        },
        "channels": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            }
          ],
          "title": "Channels"
        },
        "datasheet_ref": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Datasheet Ref"
        },
        "specs": {
          "items": {
            "$ref": "#/$defs/SpecBand"
          },
          "title": "Specs",
          "type": "array"
        }
      },
      "required": [
        "direction",
        "units"
      ],
      "title": "Characteristic",
      "type": "object"
    },
    "CompareMode": {
      "description": "Comparison direction for capability parameters.\n\nDetermines how instrument and requirement values are compared:\n- CONTAINS: Instrument range must contain required range (default)\n- HIGHER_BETTER: Instrument value must be >= required (gain, bandwidth)\n- LOWER_BETTER: Instrument value must be <= required (noise, THD)",
      "enum": [
        "contains",
        "higher_better",
        "lower_better"
      ],
      "title": "CompareMode",
      "type": "string"
    },
    "Direction": {
      "description": "Direction of signal flow for a capability.",
      "enum": [
        "input",
        "output",
        "bidir",
        "transform"
      ],
      "title": "Direction",
      "type": "string"
    },
    "MeasurementFunction": {
      "description": "Named signal measurement/stimulus functions (ATML/IEEE 1641 inspired).\n\nReplaces the Domain + SignalType pair with a single enum that describes\nwhat an instrument *does*. Grouped by IVI instrument class for clarity.",
      "enum": [
        "dc_voltage",
        "ac_voltage",
        "dc_current",
        "ac_current",
        "resistance",
        "resistance_4w",
        "capacitance",
        "inductance",
        "impedance",
        "frequency",
        "period",
        "temperature",
        "waveform",
        "dc_power",
        "ac_power",
        "sine",
        "square",
        "ramp",
        "triangle",
        "pulse",
        "arbitrary",
        "rf_power",
        "rf_cw",
        "logic",
        "counter",
        "digital_pattern",
        "serial_decode",
        "diode",
        "continuity",
        "transient",
        "s_parameters",
        "spectrum",
        "phase_noise",
        "noise_figure",
        "modulation_analysis",
        "rf_modulated",
        "noise",
        "harmonics",
        "power_quality",
        "jitter",
        "eye_diagram"
      ],
      "title": "MeasurementFunction",
      "type": "string"
    },
    "ParameterRole": {
      "description": "Role of a signal parameter in a capability.\n\nDescribes how a parameter functions within a measurement or stimulus:\n- CONTROLLABLE: Instrument can set this value (e.g., output voltage)\n- MEASURABLE: Instrument can read this value (e.g., measured voltage)\n- CAPABILITY: Performance limit of the instrument (e.g., bandwidth)\n- CONDITION: Operating condition that affects other parameters (e.g., temperature)",
      "enum": [
        "controllable",
        "measurable",
        "capability",
        "condition"
      ],
      "title": "ParameterRole",
      "type": "string"
    },
    "Pin": {
      "description": "Physical pin/pad on the DUT (ATML: Port).\n\nRepresents a single connection point that can be routed through\na fixture to an instrument. The ``role`` field classifies the pin's\npurpose (signal, ground, power, reference) for fixture routing.\n\nExample YAML:\n    pins:\n      VIN:\n        name: \"J1.1\"\n        net: \"VIN_5V\"\n        role: power\n        description: \"5V power input from bench supply\"\n      VOUT:\n        name: \"J1.3\"\n        net: \"VOUT_3V3\"\n        description: \"3.3V regulated output\"\n      GND:\n        name: \"J1.2\"\n        net: \"GND\"\n        role: ground",
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "net": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Net"
        },
        "role": {
          "$ref": "#/$defs/PinRole",
          "default": "signal"
        },
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Description"
        }
      },
      "required": [
        "name"
      ],
      "title": "Pin",
      "type": "object"
    },
    "PinRole": {
      "description": "Role of a physical DUT pin in the test system.\n\nDistinguishes signal, ground, power, and reference pins so the\nauto-match algorithm can route them correctly (e.g., ground pins\nfan out to instrument LO terminals instead of competing for\nmeasurement channels).",
      "enum": [
        "signal",
        "ground",
        "power",
        "reference"
      ],
      "title": "PinRole",
      "type": "string"
    },
    "Product": {
      "description": "Product definition (ATML: UUT Description).\n\nTop-level model that ties together:\n- Product identification (id, name, revision)\n- Documentation references (datasheet, schematic)\n- Characteristics with condition matrices\n\nExample YAML:\n    product:\n      id: power_board_v1\n      name: \"DC-DC Power Board Rev A\"\n      revision: \"A\"\n      datasheet: \"docs/DS-001.pdf\"\n\n    characteristics:\n      rail_3v3_output:\n        direction: output\n        domain: voltage\n        ...",
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "part_number": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Part Number"
        },
        "base": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Base"
        },
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Description"
        },
        "revision": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Revision"
        },
        "datasheet": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Datasheet"
        },
        "schematic": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Schematic"
        },
        "pins": {
          "additionalProperties": {
            "$ref": "#/$defs/Pin"
          },
          "title": "Pins",
          "type": "object"
        },
        "signal_groups": {
          "additionalProperties": {
            "$ref": "#/$defs/SignalGroup"
          },
          "title": "Signal Groups",
          "type": "object"
        },
        "characteristics": {
          "additionalProperties": {
            "$ref": "#/$defs/Characteristic"
          },
          "title": "Characteristics",
          "type": "object"
        }
      },
      "required": [
        "id",
        "name"
      ],
      "title": "Product",
      "type": "object"
    },
    "RangeSpec": {
      "description": "Specification for measurement or output range.",
      "properties": {
        "min": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Min"
        },
        "max": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Max"
        },
        "units": {
          "default": "",
          "title": "Units",
          "type": "string"
        }
      },
      "title": "RangeSpec",
      "type": "object"
    },
    "ResolutionSpec": {
      "description": "Specification for measurement resolution.",
      "properties": {
        "bits": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Bits"
        },
        "digits": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Digits"
        },
        "value": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Value"
        },
        "units": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Units"
        }
      },
      "title": "ResolutionSpec",
      "type": "object"
    },
    "SignalGroup": {
      "description": "Grouped signals forming a bus interface (ATML: Bus).\n\nUsed for protocols like I2C, SPI, UART where multiple signals\nmust be treated as a unit for routing and testing.\n\nExample YAML:\n    signal_groups:\n      i2c_main:\n        protocol: i2c\n        signals:\n          - pin: SDA\n            role: data\n          - pin: SCL\n            role: clock\n        parameters:\n          frequency: 400000",
      "properties": {
        "protocol": {
          "title": "Protocol",
          "type": "string"
        },
        "signals": {
          "items": {
            "$ref": "#/$defs/BusSignal"
          },
          "title": "Signals",
          "type": "array"
        },
        "parameters": {
          "additionalProperties": true,
          "title": "Parameters",
          "type": "object"
        },
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Description"
        }
      },
      "required": [
        "protocol"
      ],
      "title": "SignalGroup",
      "type": "object"
    },
    "SignalParameter": {
      "description": "A named parameter within a measurement function's capability.\n\nEach parameter describes a dimension of an instrument's capability\n(range, accuracy, resolution) or a fixed performance characteristic\n(bandwidth, sample rate).\n\nTop-level accuracy/resolution are defaults when no SpecBand matches.\nThe ``specs`` list holds condition-dependent overrides.\n\nExample YAML:\n    voltage:\n      range: {min: 0.1, max: 750, units: V}\n      accuracy: {pct_reading: 0.07, pct_range: 0.02}\n      resolution: {digits: 6.5}\n      specs:\n        - conditions:\n            frequency: {min: 3, max: 5, units: Hz}\n          accuracy: {pct_reading: 0.35, pct_range: 0.03}",
      "properties": {
        "range": {
          "anyOf": [
            {
              "$ref": "#/$defs/RangeSpec"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "accuracy": {
          "anyOf": [
            {
              "$ref": "#/$defs/AccuracySpec"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "resolution": {
          "anyOf": [
            {
              "$ref": "#/$defs/ResolutionSpec"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "value": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Value"
        },
        "units": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Units"
        },
        "role": {
          "$ref": "#/$defs/ParameterRole",
          "default": "controllable"
        },
        "specs": {
          "anyOf": [
            {
              "items": {
                "$ref": "#/$defs/SpecBand"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Specs"
        },
        "compare": {
          "anyOf": [
            {
              "$ref": "#/$defs/CompareMode"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "title": "SignalParameter",
      "type": "object"
    },
    "SpecBand": {
      "description": "Condition-dependent specification override for a parameter.\n\nEach band says \"at this operating point, here are the specs.\"\nThe ``conditions`` keys reference sibling parameter names; multiple keys\nare ANDed (all must match).  Empty dict means unconditional (always applies).\n\nExample YAML:\n    specs:\n      - conditions:\n          frequency: {min: 3, max: 5, units: Hz}\n        accuracy: {pct_reading: 0.35, pct_range: 0.03}\n      - conditions:\n          frequency: {min: 5, max: 300, units: Hz}\n        accuracy: {pct_reading: 0.07, pct_range: 0.02}",
      "properties": {
        "conditions": {
          "additionalProperties": {
            "$ref": "#/$defs/RangeSpec"
          },
          "title": "Conditions",
          "type": "object"
        },
        "value": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Value"
        },
        "accuracy": {
          "anyOf": [
            {
              "$ref": "#/$defs/AccuracySpec"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "resolution": {
          "anyOf": [
            {
              "$ref": "#/$defs/ResolutionSpec"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "title": "SpecBand",
      "type": "object"
    }
  },
  "description": "Schema for products/*/spec.yaml files.",
  "properties": {
    "product": {
      "$ref": "#/$defs/Product"
    },
    "pins": {
      "additionalProperties": {
        "$ref": "#/$defs/Pin"
      },
      "title": "Pins",
      "type": "object"
    },
    "characteristics": {
      "additionalProperties": {
        "$ref": "#/$defs/Characteristic"
      },
      "title": "Characteristics",
      "type": "object"
    },
    "signal_groups": {
      "additionalProperties": {
        "$ref": "#/$defs/SignalGroup"
      },
      "title": "Signal Groups",
      "type": "object"
    }
  },
  "required": [
    "product"
  ],
  "title": "ProductFile",
  "type": "object"
}
