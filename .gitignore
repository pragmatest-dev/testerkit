*.log

# Local databases and env files
*.duckdb
*.duckdb.wal
.env
.env.local
.env.*.local

# Brand generator font input. Outlines are shipped in the SVGs, not the font
# itself — committing the TTF would be OFL-1.1 redistribution.
branding/selawik/
